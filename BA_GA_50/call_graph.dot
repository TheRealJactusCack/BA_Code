digraph GA_run {
  rankdir=LR;
  node [shape=box];

  main [label="main_refactored.py\n(start)"];
  MainWindow [label="MainWindow (UI)"];
  start_ga [label="MainWindow.start_ga()"];
  run_ga [label="run_ga(generations)"];
  init_pop [label="init_population()"];
  random_ind [label="random_individual()"];
  rand_place [label="random_machine_nonoverlap()"];
  fitness [label="fitness(ind)"];
  occupied [label="helpers.occupied_cells()/rect_corners()"];
  selection [label="tournament_selection()/elitism"];
  crossover [label="uniform_crossover()"];
  mutate [label="mutate()"];
  update_grid [label="helpers.update_grid_counts()"];
  UI_progress [label="MainWindow._on_worker_progress/_on_worker_finished()"];

  main -> MainWindow;
  MainWindow -> update_grid [style=dashed];
  MainWindow -> start_ga;
  start_ga -> update_grid;
  start_ga -> run_ga;
  run_ga -> init_pop;
  init_pop -> random_ind;
  random_ind -> rand_place;
  run_ga -> fitness;
  fitness -> occupied;
  run_ga -> selection;
  selection -> crossover;
  crossover -> mutate;
  mutate -> occupied;
  run_ga -> UI_progress;
  UI_progress -> MainWindow;
}
